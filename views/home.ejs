<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BotHost - Hebergement bots Discord</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <section class="hero card">
        <h1>BotHost</h1>
        <p>Heberge tes bots Discord avec un compte utilisateur et un espace admin.</p>
        <div class="actions">
          <% if (!currentUser) { %>
          <a class="btn-link" href="/register">Creer un compte</a>
          <a class="btn-link secondary" href="/login">Se connecter</a>
          <% } else { %>
          <a class="btn-link" href="/dashboard">Acceder au dashboard</a>
          <% } %>
        </div>
      </section>

      <section class="card">
        <h2>Fonctionnalites</h2>
        <ul>
          <li>Connexion securisee email + mot de passe</li>
          <li>Role admin pour gerer les utilisateurs</li>
          <li>Dashboard pour enregistrer et suivre les bots</li>
        </ul>
      </section>
    </main>
  </body>
</html>
