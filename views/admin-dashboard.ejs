<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Espace admin - BotHost</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div>
        <strong><%= currentUser.email %></strong>
        <span class="badge">admin</span>
      </div>
      <div class="actions">
        <a href="/admin/users">Gestion utilisateurs</a>
        <form method="post" action="/logout">
          <button type="submit">Se deconnecter</button>
        </form>
      </div>
    </header>

    <main class="container">
      <h1>Espace admin</h1>
      <p>Tu vois tous les bots de la plateforme.</p>

      <% if (message) { %>
      <p class="message"><%= message %></p>
      <% } %>

      <form method="post" action="/bots/create" class="card inline-form">
        <input name="name" type="text" placeholder="Nom du bot" required />
        <button type="submit">Ajouter</button>
      </form>

      <section class="card">
        <% if (!bots.length) { %>
        <p>Aucun bot pour le moment.</p>
        <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Nom</th>
              <th>Statut</th>
              <th>Proprietaire</th>
              <th>Panel</th>
            </tr>
          </thead>
          <tbody>
            <% bots.forEach((bot) => { %>
            <tr>
              <td><%= bot.name %></td>
              <td><%= bot.status %></td>
              <td><%= bot.owner_email %></td>
              <td><a href="/bots/<%= bot.id %>/manage">Gerer</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </section>

      <section class="card">
        <h2>Tokens API admin (infini)</h2>
        <% if (newApiToken) { %>
        <p class="message">
          Nouveau token (copie-le maintenant):<br />
          <code><%= newApiToken %></code>
        </p>
        <% } %>
        <form method="post" action="/tokens/create" class="card form-grid">
          <input name="label" type="text" placeholder="Nom du token (ex: admin panel)" />
          <button type="submit">Generer un token admin</button>
        </form>
      </section>
    </main>
  </body>
</html>
